      intro s u
      have e1 : s - (θ a + u) = (s - u) - θ a := by ring
      have e2 : θ a + s - u = θ a + (s - u) := by ring
      rw [e1, e2, Real.cos_sub, Real.cos_add]; ring
    rw [key]; ring

/-- The real Dirichlet kernel of degree `M`. -/
noncomputable def dirichletKernel (M : ℕ) (s : ℝ) : ℝ :=
  1 + 2 * ∑ k ∈ Finset.Icc 1 M, Real.cos (2 * Real.pi * (k : ℝ) * s)

/-- The Dirichlet kernel is continuous in its argument. -/
lemma dirichletKernel_continuous (M : ℕ) : Continuous (dirichletKernel M) := by
  unfold dirichletKernel
  fun_prop

