        · norm_num [ ZMod.natCast_eq_natCast_iff' ];
          rw [ ZMod.cast_eq_val ];
          rw [ ZMod.val_natCast ];
          rw [ ZMod.natCast_eq_natCast_iff ];
          rw [ Nat.ModEq, Nat.mod_mod_of_dvd _ ( show p n i ∣ q n from
