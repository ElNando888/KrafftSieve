/--
Definition of the indicator function f.
Define the indicator function $f : \mathbb{Z}/q\mathbb{Z} \to \mathbb{R}$ such that
$f(x) = 1$ if $x \in A$, and $f(x) = 0$ otherwise.
-/
noncomputable def f (n : ℕ) (r : Fin (w n) → ℕ) (x : ZMod (q n)) : ℝ :=
  if x ∈ A n r then 1 else 0

/-
As defined previously, an integer x survives the sieve (i.e., f(x) = 1) if and only if
x is not congruent to ±r^K_i mod p_i for all 1 <= i <= w.
-/
theorem survives_iff (n : ℕ) (x : ZMod (q n)) :
    f n (r_K n) x = 1 ↔
      ∀ i : Fin (w n),
        (x.cast : ZMod (p n i)) ≠ r_K n i ∧ (x.cast : ZMod (p n i)) ≠ -r_K n i := by
      unfold f A A_i; simp +decide [Finset.mem_filter]

