          show p n i ∈ P_n n from by
            exact Finset.mem_sort ( α := ℕ ) ( · ≤ · ) |>.1 ( List.get_mem _ _ ) ) |>.2.2 ) ( by
          have := Finset.mem_filter.mp ( show p n i ∈ P_n n from by
            exact Finset.mem_sort ( α := ℕ ) ( · ≤ · ) |>.1 ( List.get_mem _ _ ) ) ; aesop; ) x
